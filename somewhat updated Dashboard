plotly_layout <- function(p, ...) {
  p %>% layout(
    plot_bgcolor  = "rgba(0,0,0,0)",
    paper_bgcolor = "rgba(0,0,0,0)",
    font  = list(family = "Barlow, sans-serif", color = "#8fa3c0", size = 12),
    xaxis = list(
      gridcolor    = "rgba(42,58,82,0.6)",
      zerolinecolor = "rgba(42,58,82,0.8)",
      tickfont = list(family = "Barlow, sans-serif", size = 11, color = "#8fa3c0"),
      titlefont = list(family = "Barlow Condensed, sans-serif", size = 13, color = "#8fa3c0")
    ),
    yaxis = list(
      gridcolor    = "rgba(42,58,82,0.6)",
      zerolinecolor = "rgba(42,58,82,0.8)",
      tickfont = list(family = "Barlow, sans-serif", size = 11, color = "#8fa3c0"),
      titlefont = list(family = "Barlow Condensed, sans-serif", size = 13, color = "#8fa3c0")
    ),
    legend = list(
      bgcolor = "rgba(22,29,46,0.8)",
      bordercolor = "rgba(42,58,82,0.8)",
      borderwidth = 1,
      font = list(family = "Barlow Condensed, sans-serif", size = 12, color = "#8fa3c0")
    ),
    hoverlabel = list(
      bgcolor = "#0a0e1a",
      bordercolor = "#2a3a52",
      font = list(family = "Barlow, sans-serif", size = 12, color = "#f0f4ff")
    ),
    margin = list(t = 20, b = 50, l = 50, r = 20),
    ...
  )
}

# Position color palette
pos_colors <- c(
  "OH"  = "#00d4b4",
  "MB"  = "#f5c518",
  "S"   = "#9b5de5",
  "OPP" = "#ff5f57",
  "DS"  = "#60a5fa",
  "L"   = "#f97316"
)

# ── Server ────────────────────────────────────────────────────────────────────
server <- function(input, output, session) {

  raw_data <- reactive({
    withProgress(message = "Loading NCAA Women's Volleyball data…", value = 0.1, {
      df <- load_data()
      incProgress(0.8)
      df
    })
  })

  filtered <- reactive({
    df <- raw_data()
    req(nrow(df) > 0)
    if (length(input$div_filter) > 0)
      df <- df[df$Division %in% input$div_filter, ]
    if (!is.null(input$season_filter) && input$season_filter != "All")
      df <- df[df$Season == input$season_filter, ]
    df <- df[df$Pos %in% names(pos_labels), ]
    df
  })

  col_name <- function(label) unname(stat_col_map[label])

  # ── Value Boxes ──────────────────────────────────────────────────────────
  output$vb_players <- renderValueBox({
    valueBox(
      format(nrow(filtered()), big.mark = ","),
      "PLAYERS", icon = icon("users"), color = "purple"
    )
  })
  output$vb_teams <- renderValueBox({
    valueBox(
      format(n_distinct(filtered()$Team), big.mark = ","),
      "TEAMS", icon = icon("trophy"), color = "blue"
    )
  })
  output$vb_positions <- renderValueBox({
    valueBox(
      n_distinct(filtered()$Pos),
      "POSITIONS", icon = icon("layer-group"), color = "orange"
    )
  })
  output$vb_avg_pts <- renderValueBox({
    avg <- round(mean(filtered()$PTS, na.rm = TRUE), 2)
    valueBox(avg, "AVG PTS/GAME", icon = icon("star"), color = "green")
  })

  # ── Overview plots ───────────────────────────────────────────────────────
  output$pos_dist_plot <- renderPlotly({
    df <- filtered() %>% count(Pos) %>% arrange(desc(n))
    colors <- pos_colors[df$Pos]
    p <- plot_ly(df, x = ~Pos, y = ~n, type = "bar",
                 marker = list(color = colors,
                               line = list(color = "rgba(0,0,0,0)", width = 0)),
                 text = ~n, textposition = "outside",
                 textfont = list(family = "Barlow Condensed", size = 13, color = "#f0f4ff"),
                 hovertemplate = "<b>%{x}</b><br>Players: %{y}<extra></extra>")
    plotly_layout(p,
                  xaxis = list(title = "", gridcolor = "rgba(0,0,0,0)",
                               tickfont = list(family = "Barlow Condensed", size = 13, color = "#8fa3c0")),
                  yaxis = list(title = "# Players"))
  })

  output$pos_pts_plot <- renderPlotly({
    df <- filtered() %>%
      group_by(Pos) %>%
      summarise(avg_pts = mean(PTS, na.rm = TRUE), .groups = "drop") %>%
      arrange(desc(avg_pts))
    colors <- pos_colors[df$Pos]
    p <- plot_ly(df, x = ~reorder(Pos, avg_pts), y = ~avg_pts, type = "bar",
                 marker = list(color = colors,
                               line = list(color = "rgba(0,0,0,0)", width = 0)),
                 text = ~round(avg_pts, 2), textposition = "outside",
                 textfont = list(family = "Barlow Condensed", size = 13, color = "#f0f4ff"),
                 hovertemplate = "<b>%{x}</b><br>Avg PTS/G: %{y:.2f}<extra></extra>")
    plotly_layout(p,
                  xaxis = list(title = "", gridcolor = "rgba(0,0,0,0)",
                               tickfont = list(family = "Barlow Condensed", size = 13, color = "#8fa3c0")),
                  yaxis = list(title = "Avg PTS/G"))
  })

  output$top_scorers_plot <- renderPlotly({
    df <- filtered() %>%
      filter(!is.na(PTS), GP >= 5) %>%
      arrange(desc(PTS)) %>%
      slice_head(n = 10)
    colors <- pos_colors[df$Pos]
    p <- plot_ly(df,
                 x = ~reorder(Player, PTS), y = ~PTS,
                 type = "bar",
                 marker = list(color = colors,
                               line = list(color = "rgba(0,0,0,0)", width = 0)),
                 text  = ~paste0(Player, "\n", Team, " · ", Pos),
                 hovertemplate = "<b>%{text}</b><br>PTS/G: %{y:.2f}<extra></extra>")
    plotly_layout(p,
                  xaxis = list(title = "", tickangle = -30,
                               tickfont = list(family = "Barlow", size = 11, color = "#8fa3c0")),
                  yaxis = list(title = "PTS/G"))
  })

  # ── Player Table ─────────────────────────────────────────────────────────
  output$player_table <- renderDT({
    df <- filtered()
    if (length(input$pos_filter) > 0) df <- df[df$Pos %in% input$pos_filter, ]
    if (input$yr_filter != "All")     df <- df[df$Yr  == input$yr_filter, ]
    df <- df[!is.na(df$GP) & df$GP >= input$min_gp, ]

    pg_cols <- intersect(per_game_stats, names(df))
    df[pg_cols] <- lapply(df[pg_cols], function(x) round(x, 3))

    display_cols <- c("Season", "Player", "Team", "Conference", "Yr", "Pos",
                      "Division", "GP", "S",
                      "Kills", "Hit Pct", "Assists", "Aces",
                      "Digs", "Block Solos", "Block Assists", "PTS")
    display_cols <- intersect(display_cols, names(df))

    pg_rename <- c(Kills = "Kills/G", Assists = "Assists/G", Aces = "Aces/G",
                   Digs = "Digs/G", PTS = "PTS/G",
                   "Block Solos" = "BlkSolo/G", "Block Assists" = "BlkAst/G")
    colnames_display <- ifelse(display_cols %in% names(pg_rename),
                               pg_rename[display_cols], display_cols)
    out <- df[, display_cols]
    names(out) <- colnames_display

    datatable(out,
              filter  = "top",
              options = list(
                pageLength = 15, scrollX = TRUE,
                order = list(list(which(colnames_display == "PTS/G") - 1, "desc")),
                dom = "Bfrtip",
                initComplete = JS(
                  "function(settings, json) {",
                  "  $(this.api().table().header()).css({'background-color':'#1e2a3e','color':'#8fa3c0'});",
                  "}"
                )
              ),
              rownames = FALSE,
              class = "compact") %>%
      formatStyle("Pos",
                  backgroundColor = styleEqual(
                    c("OH",      "MB",      "S",       "OPP",     "DS",      "L"),
                    c("#00d4b4","#f5c518","#9b5de5","#ff5f57","#60a5fa","#f97316")
                  ),
                  color = styleEqual(
                    c("OH",      "MB",      "S",       "OPP",     "DS",      "L"),
                    c("#0a0e1a","#0a0e1a","#f0f4ff","#f0f4ff","#0a0e1a","#0a0e1a")
                  ),
                  fontWeight = "bold",
                  borderRadius = "4px",
                  padding = "2px 8px") %>%
      formatStyle("PTS/G",
                  background = styleColorBar(range(out[["PTS/G"]], na.rm = TRUE), "#00d4b420"),
                  backgroundSize = "100% 80%",
                  backgroundRepeat = "no-repeat",
                  backgroundPosition = "center")
  })

  # ── Position Comparison ──────────────────────────────────────────────────
  output$comp_plot <- renderPlotly({
    df <- filtered()
    if (length(input$comp_pos) == 0) return(NULL)
    df <- df[df$Pos %in% input$comp_pos, ]
    cname <- col_name(input$comp_stat)

    summary_df <- df %>%
      group_by(Pos) %>%
      summarise(val = if (input$comp_type == "Mean")
                        mean(get(cname),   na.rm = TRUE)
                      else
                        median(get(cname), na.rm = TRUE),
                n = n(), .groups = "drop") %>%
      arrange(desc(val))

    colors <- pos_colors[summary_df$Pos]

    p <- plot_ly(summary_df,
                 x = ~reorder(Pos, val), y = ~val, type = "bar",
                 marker = list(color = colors,
                               line = list(color = "rgba(0,0,0,0)", width = 0)),
                 text = ~paste0("n = ", n),
                 textposition = "outside",
                 textfont = list(family = "Barlow Condensed", size = 12, color = "#8fa3c0"),
                 hovertemplate = "<b>%{x}</b><br>%{y:.3f}<extra></extra>")

    plotly_layout(p,
                  xaxis = list(title = ""),
                  yaxis = list(title = paste(input$comp_type, input$comp_stat)),
                  showlegend = FALSE,
                  title = list(
                    text = paste(input$comp_type, "·", input$comp_stat, "by Position"),
                    font = list(family = "Barlow Condensed", size = 15, color = "#f0f4ff"),
                    x = 0.01
                  ))
  })

  output$violin_plot <- renderPlotly({
    df <- filtered()
    if (length(input$comp_pos) == 0) return(NULL)
    df <- df[df$Pos %in% input$comp_pos, ]
    cname <- col_name(input$comp_stat)
    df <- df[!is.na(df[[cname]]), ]

  # Build one trace per position for custom colors
    hex_to_rgba <- function(hex, alpha = 0.15) {
      r <- strtoi(substr(hex, 2, 3), 16L)
      g <- strtoi(substr(hex, 4, 5), 16L)
      b <- strtoi(substr(hex, 6, 7), 16L)
      sprintf("rgba(%d,%d,%d,%.2f)", r, g, b, alpha)
    }
    positions <- sort(unique(df$Pos))
    p <- plot_ly(type = "violin")
    for (pos in positions) {
      sub <- df[df$Pos == pos, ]
      p <- add_trace(p,
        y = sub[[cname]],
        x = rep(pos, nrow(sub)),
        name = pos,
        type = "violin",
        box = list(visible = TRUE),
        meanline = list(visible = TRUE, color = "#f5c518"),
        points = "outliers",
        line = list(color = pos_colors[pos]),
        fillcolor = hex_to_rgba(pos_colors[pos], 0.15),
        marker = list(color = pos_colors[pos], size = 4, opacity = 0.5),
        hoverinfo = "y+name"
      )
    }

    plotly_layout(p,
                  xaxis = list(title = ""),
                  yaxis = list(title = input$comp_stat),
                  showlegend = FALSE,
                  violingap = 0.05,
                  violingroupgap = 0)
  })

  # ── Scatter Plot ─────────────────────────────────────────────────────────
  output$scatter_plot <- renderPlotly({
    df <- filtered()
    if (length(input$sc_pos) == 0) return(NULL)
    df <- df[df$Pos %in% input$sc_pos, ]
    df <- df[!is.na(df$GP) & df$GP >= input$sc_min_gp, ]

    cx <- col_name(input$sc_x)
    cy <- col_name(input$sc_y)
    cz <- col_name(input$sc_col)
    df <- df[!is.na(df[[cx]]) & !is.na(df[[cy]]) & !is.na(df[[cz]]), ]

    pos_symbols <- c(
      "OH"  = "circle",
      "MB"  = "square",
      "S"   = "triangle-up",
      "OPP" = "diamond",
      "DS"  = "cross",
      "L"   = "star"
    )

    col_vals  <- df[[cz]]
    col_range <- range(col_vals, na.rm = TRUE)

    positions <- sort(unique(df$Pos))
    p <- plot_ly(type = "scatter", mode = "markers")

    for (i in seq_along(positions)) {
      pos <- positions[i]
      sub <- df[df$Pos == pos, ]
      if (nrow(sub) == 0) next
      p <- add_trace(p,
        data        = sub,
        x           = ~get(cx),
        y           = ~get(cy),
        name        = pos,
        legendgroup = pos,
        showlegend  = TRUE,
        text        = ~paste0(
          "<b>", Player, "</b>",
          "<br>", Team, " · ", Pos, " · ", Yr,
          "<br>", input$sc_x, ": <b>", round(get(cx), 3), "</b>",
          "<br>", input$sc_y, ": <b>", round(get(cy), 3), "</b>",
          "<br>", input$sc_col, ": <b>", round(get(cz), 3), "</b>"
        ),
        hoverinfo = "text",
        marker = list(
          symbol    = pos_symbols[[pos]],
          color     = ~get(cz),
          colorscale = list(
            c(0, "#0a1628"), c(0.25, "#0d4f8c"), c(0.5, "#00d4b4"),
            c(0.75, "#f5c518"), c(1, "#ff5f57")
          ),
          cmin      = col_range[1],
          cmax      = col_range[2],
          showscale = (i == 1),
          colorbar  = list(
            title = list(text = input$sc_col,
                         font = list(family = "Barlow Condensed", size = 12, color = "#8fa3c0")),
            tickfont = list(family = "Barlow", size = 10, color = "#8fa3c0"),
            bgcolor = "rgba(22,29,46,0.8)",
            bordercolor = "rgba(42,58,82,0.8)",
            borderwidth = 1,
            thickness = 14
          ),
          size      = 9,
          opacity   = 0.85,
          line      = list(width = 1, color = "rgba(255,255,255,0.2)")
        )
      )
    }

    plotly_layout(p,
                  xaxis = list(title = input$sc_x),
                  yaxis = list(title = input$sc_y),
                  legend = list(
                    title = list(
                      text = "<b>Shape = Position</b>",
                      font = list(family = "Barlow Condensed", size = 12, color = "#8fa3c0")
                    )
                  ))
  })
}

# ── Run App ───────────────────────────────────────────────────────────────────
shinyApp(ui, server)
